# SmartDesk AI — Environment Variables
# Copy to .env and fill in your values. Never commit .env to source control.

# ─── Supabase / Postgres ─────────────────────────────────
# Transaction-mode pooler (port 6543) — used by the pg Pool in src/db/supabase.js
DATABASE_URL=postgresql://postgres.wumklkcucvcqcdcpoduu:Aaris%40%232617@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
# JS client (used by supabaseClient.js for auth / realtime, if needed)
SUPABASE_URL=https://wumklkcucvcqcdcpoduu.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Use the service role key only in trusted server-side code:
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── IBM watsonx Orchestrate ─────────────────────────────
WATSONX_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=optional_for_legacy_classification
WATSONX_API_URL=https://api.au-syd.watson-orchestrate.cloud.ibm.com/instances/your-instance-id
WATSONX_AGENT_ID=your_orchestrate_agent_id_here
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2

# ─── Vite renderer (browser-side Supabase client) ────────
# These are safe to expose to the renderer — they are the public anon key only
VITE_SUPABASE_URL=https://wumklkcucvcqcdcpoduu.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Backend ─────────────────────────────────────────────
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001
NODE_ENV=development
