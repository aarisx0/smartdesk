{
  "name": "smartdesk-ai",
  "version": "1.0.0",
  "description": "AI-powered desktop file organizer using IBM watsonx Orchestrate",
  "main": "dist/main/bootstrap.js",
  "scripts": {
    "predev": "npx kill-port 5173 3001 --silent || true",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:backend\" \"npm run dev:electron\"",
    "dev:renderer": "vite --config vite.config.ts",
    "dev:backend": "nodemon --watch src/backend --watch src/db src/backend/server.js",
    "dev:electron": "wait-on http://localhost:5173 && npm run build:main && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build --config vite.config.ts",
    "build:main": "tsc -p tsconfig.main.json && node scripts/copy-runtime.js",
    "copy:runtime": "node scripts/copy-runtime.js",
    "copy:splash": "if not exist dist\\main md dist\\main & copy /Y src\\main\\splash.html dist\\main\\splash.html",
    "dist": "npm run build && electron-builder",
    "lint": "eslint src --ext .ts,.tsx,.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "axios": "^1.7.2",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "electron-store": "^8.2.0",
    "exiftool-vendored": "^36.0.0",
    "express": "^4.19.2",
    "framer-motion": "^11.2.11",
    "lucide-react": "^0.471.0",
    "mammoth": "^1.8.0",
    "mime-types": "^2.1.35",
    "pdf-parse": "^1.1.1",
    "pg": "^8.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^3.0.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9.5.0",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^6.0.0",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "tar": "^6.2.1",
    "nth-check": "^2.0.1",
    "marked": "^4.3.0",
    "trim-newlines": "^4.1.1",
    "esbuild": "^0.25.0",
    "xlsx": "^0.18.5",
    "xmldom": "^0.5.0",
    "got": "^11.8.6"
  },
  "build": {
    "appId": "com.smartdesk.ai",
    "productName": "SmartDesk AI",
    "copyright": "Copyright © 2026 SmartDesk AI",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json",
      ".env.example"
    ],
    "asarUnpack": [
      "dist/backend/**/*",
      "dist/db/**/*",
      "dist/watcher/**/*",
      "dist/main/env-loader.js"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": ["**/*"]
      },
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "executableName": "SmartDesk AI",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SmartDesk AI",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "displayLanguageSelector": false,
      "perMachine": false,
      "allowElevation": true,
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  }
}
